# ── Oracle DB (external — không include trong compose) ──────────────────────
DB_HOST=your-oracle-host
DB_PORT=1521
DB_NAME=XEPDB1
DB_USERNAME=ticketbox
DB_PASSWORD=your_db_password

# ── JWT ──────────────────────────────────────────────────────────────────────
# Tạo bằng: openssl rand -base64 64
JWT_SECRET=your_jwt_secret_at_least_64_chars

# ── VNPay sandbox ─────────────────────────────────────────────────────────────
VNPAY_TMN_CODE=43V50SJT
VNPAY_HASH_SECRET=your_vnpay_hash_secret
VNPAY_RETURN_URL=http://localhost:3000/payment/vnpay-return

# ── Email (Resend) ────────────────────────────────────────────────────────────
MAIL_API_KEY=re_your_resend_api_key
MAIL_FROM=noreply@yourdomain.com
ADMIN_EMAIL=admin@yourdomain.com

# ── Cloudinary ────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Google OAuth2 (optional) ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Next.js build arg ─────────────────────────────────────────────────────────
# Dùng khi build Docker image frontend — URL backend từ browser gọi tới
NEXT_PUBLIC_API_URL=http://localhost:8083
